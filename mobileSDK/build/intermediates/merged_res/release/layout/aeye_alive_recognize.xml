<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >


	<com.aeye.face.view.AutoFitSurfaceView
		android:id="@+id/preview_view1"
		android:layout_alignParentTop="true"
		android:layout_centerHorizontal="true"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content" />

    <com.aeye.face.view.FaceView
        android:id="@+id/faceRect"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

	<com.aeye.face.lightView.CheckFaceView
		android:id="@+id/facebgview"
		android:layout_width="fill_parent"
		android:layout_height="fill_parent"/>

    <RelativeLayout
        android:id="@+id/faceStatus"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
       >

        <FrameLayout
            android:id="@+id/face_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:orientation="horizontal" >

            <TextView
                android:id="@+id/tvTop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/face_theme_primary"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/ivReturn"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="10dp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="10dp"
                android:background="@drawable/aeye_return" />
            
            <ImageView
                android:id="@+id/ivVoice"
                android:layout_marginRight="10dp"
                android:layout_marginTop="10dp"
                android:layout_gravity="right"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="10dp"
                android:background="@drawable/aeye_selector_voice" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="fill_parent"
            android:orientation="vertical" >

            <Space
                android:id="@+id/face_toolbar_gap"
                android:layout_width="match_parent"
                android:layout_height="56dp" />

				<TextView
					android:id="@+id/tvHint"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="top|center_horizontal"
					android:gravity="center"
					android:text="请拿起手机,对准屏幕"
					android:textColor="@color/black"
					android:textSize="22sp" />
                
                <TextView
                    android:id="@+id/tvCheckHint"
                    android:layout_width="wrap_content"
                    android:layout_height="50dip"
                    android:layout_gravity="bottom|center_horizontal"
					android:textColor="@color/green"
                    android:gravity="center"
                    android:textSize="17dip" />

                <ImageView
                    android:id="@+id/ivNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/aeye_anim_count" />
                
                <TextView 
			        android:id="@+id/tvEnvHint"
			        android:layout_width="wrap_content"
			        android:layout_height="wrap_content"
			        android:drawableLeft="@drawable/aeye_anim_tip"
			        android:background="@drawable/aeye_selector_hit"
			       	android:layout_gravity="center"
			       	android:textSize="20sp"
					android:visibility="gone"
			       	android:textColor="@android:color/black"
			       	android:gravity="center" />
                

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dip"
                android:layout_weight="2"
				android:visibility="gone"
                android:orientation="horizontal" >

                <Space
                    android:layout_width="0dip"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:padding="0dp" />

                <com.aeye.face.view.CountView                 
                    android:id="@+id/tvRecogTimeCountdown"
                    android:layout_width="0dip"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <FrameLayout 
        android:id="@+id/introduceView"
	    android:layout_width="match_parent"
	    android:layout_height="match_parent"
	    android:visibility="gone" >
	    
	    <ImageView 
	        android:layout_width="match_parent"
	        android:layout_height="match_parent"
	        android:scaleType="fitXY"
	        android:src="@drawable/aeye_introduce"/>
	    
	   	<TextView 
	        android:id="@+id/introduceBegin"
	        android:background="@drawable/aeye_itd_btn_bg"
	        android:layout_width="wrap_content"
	        android:layout_height="wrap_content"
	        android:layout_marginBottom="30dp"
	        android:layout_gravity="center_horizontal|bottom"
	        android:gravity="center"
	        android:textColor="@color/white"
	        android:textSize="20sp"
	        android:text="@string/aeye_begin_recog"/>
	
	</FrameLayout>


</RelativeLayout>